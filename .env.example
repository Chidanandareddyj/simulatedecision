# External Postgres (required)
DATABASE_URL=postgresql://user:password@host:5432/delhi_twin

# GitHub Models (required for live polls; tests use mocks)
# Create a PAT with models:read at https://github.com/settings/tokens
GITHUB_TOKEN=github_pat_...

# Optional: override inference endpoint (default: https://models.github.ai/inference)
# GITHUB_MODELS_BASE_URL=https://models.github.ai/inference

# Model + poll defaults (GitHub Models: openai/gpt-4o)
DEFAULT_MODEL=openai/gpt-4o
LLM_MAX_TOKENS=1000
POPULATION_SEED=42
MAX_CLUSTERS=160
BOOTSTRAP_SAMPLES=500

# Optional OpenRouter fallback (used only if GITHUB_TOKEN is unset)
# OPENROUTER_API_KEY=sk-or-v1-...
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
